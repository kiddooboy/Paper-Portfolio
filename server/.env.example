# ── Firebase / Google Sign-In ──────────────────────────────────────────────────
# Required for "Continue with Google" to work.
# Get from: Firebase Console → Project Settings → Service Accounts
#           → Generate new private key → download the JSON file
# Paste the ENTIRE JSON as one single line below (keep \n as literal \n, not real newlines)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"YOUR_PROJECT_ID","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"...","universe_domain":"googleapis.com"}

# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=replace-with-a-long-random-secret

# ── Admin account bootstrap ────────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=choose-a-secure-password
ADMIN_NAME=Admin

# ── Server ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
# DB_PATH=/home/ubuntu/paper-portfolio/data/papertrading.db  # optional override

# ── SMTP (for forgot-password OTP emails) ──────────────────────────────────────
# Leave blank to disable email; forgot-password will return an error if unset.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=you@gmail.com
