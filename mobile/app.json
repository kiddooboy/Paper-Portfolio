    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "paperportfolio",
    "android": {
      "package": "com.sccl.paperportfolio",
      "googleServicesFile": "./google-services.json"
    },
    "ios": {
      "bundleIdentifier": "com.paperportfolio.app"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "c6b2608e-c63e-48a9-a10e-7a237a927fe8"
      }
    }
  }
}
